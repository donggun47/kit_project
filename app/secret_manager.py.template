import os
from dotenv import load_dotenv

# Load secret environment variables
load_dotenv()

def get_secret(key_name, prompt_msg="Enter Secret: "):
    """
    Unified secret retrieval system.
    Tries 1) Environment Variables, 2) Manual Input.
    """
    # 1. Try Environment Variable (from .env or System)
    secret = os.getenv(key_name)
    if secret:
        return secret

    # 2. Fallback to Manual Input
    print(f"\n[SECURITY] {key_name} not found in environment.")
    return input(prompt_msg).strip()

if __name__ == "__main__":
    # Test retrieval
    test_key = get_secret("OPENAI_API_KEY")
    print(f"Key loaded (len): {len(test_key) if test_key else 0}")
